# Database Configuration
MONGODB_URI=mongodb://localhost:27017/fpt_chatbot
MASTER_MONGODB_URI=mongodb://localhost:27017/fpt_chatbot_master
TENANT_DB_PREFIX=fpt_tenant_

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Super Admin Configuration
SUPER_ADMIN_EMAIL=admin@fptchatbot.com
SUPER_ADMIN_PASSWORD=SuperAdmin123!

# Migration Configuration
MIGRATION_KEY=migrate-fpt-chatbot-2024

# Default Tenant Configuration
DEFAULT_TENANT_NAME=FPT Software

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Email Configuration (for invitations)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@fptchatbot.com

# Optional: Custom Domain Support
CUSTOM_DOMAINS=true
DEFAULT_DOMAIN=fptchatbot.com

# Security
CORS_ORIGINS=http://localhost:3000,https://*.fptchatbot.com
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Feature Flags
ENABLE_SELF_REGISTRATION=true
ENABLE_CUSTOM_BRANDING=true
ENABLE_API_ACCESS=true

# Monitoring (optional)
SENTRY_DSN=
ANALYTICS_ID=

# File Upload (optional)
MAX_FILE_SIZE=10MB
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# Cache Configuration (optional)
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600
x